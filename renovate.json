{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "* * 1 * *"
  ],
  "prConcurrentLimit": 20,
  "prHourlyLimit": 0,
  "github-actions": {
    "fileMatch": [
      "^\\.github/workflows/[^/]+\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "maven"
      ],
      "matchFileNames": [
        "pom.xml",
        "graylog-api/**",
        "graylog-archiving-plugin/**"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "groupName": "patch"
    },
    {
      "matchManagers": [
        "maven"
      ],
      "matchFileNames": [
        "pom.xml",
        "graylog-api/**",
        "graylog-archiving-plugin/**"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "groupName": "minor"
    },
    {
      "matchManagers": [
        "maven"
      ],
      "matchFileNames": [
        "pom.xml",
        "graylog-api/**",
        "graylog-archiving-plugin/**"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major"
    }
  ]
}
